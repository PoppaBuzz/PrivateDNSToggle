<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android"
    android:opacity="opaque">
    <!-- Dark background -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#262828" />
            <corners android:radius="16dp" />
        </shape>
    </item>

    <!-- Shield icon left side -->
    <item android:gravity="left|center_vertical">
        <scale
            android:scaleWidth="30%"
            android:scaleHeight="80%"
            android:scaleGravity="left|center_vertical">
            <shape android:shape="rectangle">
                <solid android:color="#0de2d2" />
            </shape>
        </scale>
    </item>

    <!-- Right panel controls hint -->
    <item android:gravity="right|center_vertical">
        <scale
            android:scaleWidth="60%"
            android:scaleHeight="60%"
            android:scaleGravity="right|center_vertical">
            <shape android:shape="rectangle">
                <solid android:color="#1f1f1f" />
                <stroke android:width="1dp" android:color="#404040" />
            </shape>
        </scale>
    </item>
</layer-list>
