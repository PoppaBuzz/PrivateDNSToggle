<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.WRITE_SECURE_SETTINGS" />
    <uses-permission android:name="android.permission.INTERACT_ACROSS_USERS_FULL" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.QuickDNS">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.QuickDNS">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name=".tile.PrivateDNSTile"
            android:label="quickDNS"
            android:icon="@drawable/ic_shield_active"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE"
            android:exported="true">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <activity
            android:name=".DNSProviderActivity"
            android:theme="@style/Theme.QuickDNS"
            android:exported="true" />

        <provider
            android:name="rikka.shizuku.ShizukuProvider"
            android:authorities="com.jphat.quickdns.shizuku"
            android:multiprocess="false"
            android:enabled="true"
            android:exported="true"
            android:permission="android.permission.INTERACT_ACROSS_USERS_FULL" />

        <receiver
            android:name=".widget.PrivateDNSWidget"
            android:label="quickDNS Shield Toggle"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.jphat.quickdns.ACTION_TOGGLE_DNS" />
                <action android:name="com.jphat.quickdns.ACTION_OPEN_SETTINGS" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_info" />
        </receiver>

        <receiver
            android:name=".widget.PrivateDNSWidgetLarge"
            android:label="quickDNS Large Toggle"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.jphat.quickdns.ACTION_TOGGLE_DNS_LARGE" />
                <action android:name="com.jphat.quickdns.ACTION_OPEN_SETTINGS_LARGE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_info_large" />
        </receiver>

        <receiver
            android:name=".widget.PrivateDNSWidgetTile"
            android:label="quickDNS Tile Toggle"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.jphat.quickdns.ACTION_TOGGLE_DNS_TILE" />
                <action android:name="com.jphat.quickdns.ACTION_OPEN_SETTINGS_TILE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_info_compact_tile" />
        </receiver>

        <receiver
            android:name=".widget.WidgetUpdateReceiver"
            android:label="Widget Update Coordinator"
            android:exported="true">
            <intent-filter>
                <action android:name="com.jphat.quickdns.ACTION_UPDATE_ALL_WIDGETS" />
            </intent-filter>
        </receiver>
    </application>

</manifest>